# Database — SQLite path (zero config, no setup needed)
DATABASE_PATH="./data/dev.db"

# JWT secret — generate a strong random string for production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3002

# CORS — frontend origin
CORS_ORIGIN="http://localhost:8080"

# Logging — debug | info | warn | error
LOG_LEVEL="debug"

# Environment — development | production
NODE_ENV="development"

# OAuth — Google (create at https://console.cloud.google.com)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OAuth — GitHub (create at https://github.com/settings/developers)
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# URLs used by OAuth callbacks
APP_BASE_URL="http://localhost:3002"
FRONTEND_URL="http://localhost:8080"

# Optional — bcrypt rounds (default: 12)
# BCRYPT_ROUNDS=12

# Email — SMTP (leave blank to skip sending; reset token logged to console instead)
# Works with any SMTP provider: Gmail, Mailgun, Resend SMTP bridge, Mailtrap, etc.
# SMTP_HOST="smtp.mailgun.org"
# SMTP_PORT="587"
# SMTP_USER="postmaster@mg.yourdomain.com"
# SMTP_PASS="your-smtp-password"
# SMTP_SECURE="false"           # true = TLS/465, false = STARTTLS/587
# SMTP_FROM="CoFounder Connect <noreply@yourdomain.com>"

# Mailtrap (local dev email testing — https://mailtrap.io)
# SMTP_HOST="sandbox.smtp.mailtrap.io"
# SMTP_PORT="2525"
# SMTP_USER="<mailtrap-user>"
# SMTP_PASS="<mailtrap-pass>"
